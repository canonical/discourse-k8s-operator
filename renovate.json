{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:base"
  ],
  "ignoreDeps": [
    "pydantic"
  ],
  "packageRules": [
    {
      "enabled": true,
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "enabled": false,
      "matchFiles": [
        "rockcraft.yaml"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ]
    },
    {
      "description": "Group LocalStack CLI and Docker image updates into a single PR to keep versions in sync",
      "groupName": "localstack",
      "matchPackageNames": [
        "localstack",
        "localstack/localstack"
      ],
      "pinDigests": false
    }
  ],
  "regexManagers": [
    {
      "description": "Update LocalStack CLI (PyPI) and Docker image versions in localstack-installation.sh",
      "fileMatch": [
        "(^|/)localstack-installation\\.sh$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\n]+)\\n[A-Z_]+_VERSION=[\"']?(?<currentValue>[^\"'\\n\\s]+)[\"']?"
      ]
    },
    {
      "datasourceTemplate": "docker",
      "description": "Update base image references",
      "fileMatch": [
        "(^|/)rockcraft.yaml$"
      ],
      "matchStrings": [
        "# renovate: build-base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?",
        "# renovate: base:\\s+(?<depName>[^:]*):(?<currentValue>[^\\s@]*)(@(?<currentDigest>sha256:[0-9a-f]*))?"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "ubuntu"
    },
    {
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "discourse/discourse",
      "description": "Update discourse",
      "fileMatch": [
        "(^|/)rockcraft.yaml$"
      ],
      "matchStrings": [
        "source:.*discourse/discourse\\.git.*\\n.*source-depth: 1.*\\n.*source-tag: (?<currentValue>.+)"
      ],
      "matchStringsStrategy": "any",
      "versioningTemplate": "regex:^v?(?<major>\\d{4})\\.(?<minor>\\d+)\\.(?<patch>\\d+)-latest$"
    }
  ],
  "schedule": [
    "* * * * 0,6"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
